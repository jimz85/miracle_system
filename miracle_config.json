{
  "version": "1.0.1",
  "trading": {
    "min_trades_per_day": 1,
    "max_trades_per_day": 5,
    "min_trade_interval_hours": 2,
    "max_consecutive_same_direction": 3,
    "consecutive_loss_pause_hours": 24
  },
  "position": {
    "base_position_pct": 2,
    "max_position_pct": 15,
    "max_total_exposure": 40,
    "gradual_steps": {
      "enabled": true,
      "max_step": 3,
      "step_increment_pct": 4.5
    }
  },
  "leverage": {
    "strong_trend": {"min_adx": 35, "leverage": 3, "multiplier": 1.5},
    "medium_trend": {"min_adx": 20, "leverage": 2, "multiplier": 1.0},
    "weak_trend": {"min_adx": 0, "leverage": 1, "multiplier": 0.5}
  },
  "risk": {
    "max_loss_per_trade_pct": 1,
    "atr_stop_multiplier": 3,
    "min_rr_ratio": 2.0,
    "max_hold_hours": 24,
    "daily_loss_stop_pct": 5,
    "total_drawdown_stop_pct": 20
  },
  "factors": {
    "price_momentum": {"weight": 0.6, "indicators": ["rsi", "adx", "macd"]},
    "news_sentiment": {"weight": 0.2},
    "onchain": {"weight": 0.1, "metrics": ["exchange_flow", "large_transfer"]},
    "wallet": {"weight": 0.1, "metrics": ["holder_concentration"]}
  },
  "feishu": {
    "enabled": true
  },
  "exchanges": ["okx", "binance"],
  "fee": {
    "maker": 0.0002,
    "taker": 0.0005,
    "estimated_slippage": 0.005
  }
