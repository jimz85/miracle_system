  "strategy_descriptions": {
    "RSI_MR": "RSI均值回归：RSI<30 + ADX>15买入，RSI>70卖出。适合DOGE/BTC/SOL/LINK等主流币。",
    "RSI_EMAn": "RSI+EMA共振：RSI<35 + EMA多头排列 + ADX>15买入。适合BNB/XRP等中等市值币。",
    "RSI_VOL": "RSI+成交量混合：RSI<35 + vol_ratio>1.5 + ADX>15买入。适合DOT。",
    "VOL_BRK": "成交量突破策略：vol_ratio>2× AND ADX>20买入，vol<MA平仓。适合小币和熊市。",
    "BB_TREND": "布林带趋势跟踪：RSI<30 + ADX>20 + BB下轨位置<15买入。适合ADA等小币种。"
  },
  "market_environment_rules": {
    "bear_market": {
      "btc_condition": "price < BTC_MA200",
      "recommended_strategies": ["VOL_BRK"],
      "description": "熊市（大币跌穿MA200）：倾向VOL_BRK（大波动突破），避免RSI_MR抄底"
    },
    "bull_market": {
      "btc_condition": "price > BTC_MA200 AND RSI_4H < 70",
      "recommended_strategies": ["RSI_MR", "RSI_EMAn"],
      "description": "牛市：倾向RSI均值回归策略，胜率更高"
    },
    "recovery": {
      "btc_condition": "price > BTC_MA200 AND RSI_4H > 70",
      "recommended_strategies": ["VOL_BRK", "RSI_MR"],
      "description": "反弹期：高位RSI避免追涨，用VOL_BRK或空头保护"
    }
  },
