# Miracle System - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===========================================
# API Keys
# ===========================================

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# OpenAI GPT API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ===========================================
# LLM Fallback Configuration
# ===========================================

# Primary LLM provider (claude, gpt, deepseek, gemini, ollama)
LLM_PRIMARY_PROVIDER=claude

# Fallback LLM provider (activated when primary fails)
LLM_FALLBACK_PROVIDER=deepseek

# Enable automatic fallback on failure (true/false)
LLM_AUTO_FALLBACK=true

# Max retry attempts before switching to fallback
LLM_MAX_RETRIES=3

# ===========================================
# Exchange API Keys
# ===========================================

# Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# OKX (if used)
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

# ===========================================
# Feishu (Lark) Configuration
# ===========================================

FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_WEBHOOK_URL=your_feishu_webhook_url_here

# ===========================================
# Trading Configuration
# ===========================================

# Trading mode: SIMULATION or LIVE
TRADING_MODE=SIMULATION

# Enable emergency stop API (true/false)
EMERGENCY_STOP_ENABLED=true

# API authentication token for emergency stop
EMERGENCY_STOP_TOKEN=your_emergency_stop_token_here

# ===========================================
# Server Configuration
# ===========================================

# API Server port
API_PORT=8080

# API Server host
API_HOST=0.0.0.0

# Enable debug mode
DEBUG=false

# ===========================================
# Logging
# ===========================================

LOG_LEVEL=INFO
LOG_FILE=miracle.log
